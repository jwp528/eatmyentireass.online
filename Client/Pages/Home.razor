@page "/"
@using BlazorApp.Client.Components
@using BlazorApp.Client.Services
@using static BlazorApp.Shared.Assets
@inject IJSRuntime js
@inject ILeaderboardService LeaderboardService
@inject ISettingsService SettingsService
@inject IPlayerService PlayerService
@inject IVersionCheckService VersionCheckService
@inject IStatsService StatsService
@inject ICollectionService CollectionService
@inject IDailyChallengeService DailyChallengeService
@inject IProgressService ProgressService
@inject NavigationManager NavigationManager

<PageTitle>Eat my entire ass</PageTitle>

<div class="app-shell">

    <header class="app-bar">
        <div class="app-bar-brand">
            <img src="/icon-192.png" alt="EMEA" width="28" class="app-bar-icon" />
            <span class="app-bar-title">EMEA</span>
        </div>

        <nav class="app-bar-actions">
            <button class="icon-btn" @onclick="ShowHelpDialog" title="How to Play">
                <i class="fas fa-book-open"></i>
            </button>
            <button class="icon-btn" @onclick="ShowLeaderboardStatsDialog" title="Leaderboard &amp; Stats">
                <i class="fas fa-trophy"></i>
            </button>
            <button class="icon-btn" @onclick="ShowAssdexDialog" title="Assdex">
                <Assdex Size="1.2em" Style="Assdex.AssdexIconStyle.Outline" Color="currentColor" />
            </button>
        </nav>

        <div class="app-bar-end">
            <button class="icon-btn @(playSounds ? "icon-btn-active" : "")" @onclick="ToggleSound"
                    title="@(playSounds ? "Sound On" : "Sound Off")">
                <i class="@(playSounds ? "bi bi-volume-up-fill" : "bi bi-volume-mute-fill")"></i>
            </button>
            <button class="icon-btn" @onclick="ShowAboutDialog" title="About">
                <i class="fas fa-info-circle"></i>
            </button>
        </div>
    </header>

    <main class="game-main @(gamePlaying && frenzyActive ? "frenzy-active" : "")"
          @onclick="EatPiece"
          @onmousedown="OnFrenzyHoldStart" @onmouseup="OnFrenzyHoldEnd" @onmouseleave="OnFrenzyHoldEnd"
          role="button" tabindex="0">

        @* Challenge banner — top-left, dismissible *@
        @if (_challengeScore > 0 && _showChallengeBanner)
        {
            <div class="challenge-banner" @onclick:stopPropagation="true">
                <i class="bi bi-trophy-fill challenge-banner-icon"></i>
                <span>Beat <strong>@_challengerName</strong>'s score of <strong>@((int)_challengeScore)</strong>!</span>
                <button class="challenge-banner-dismiss" @onclick="() => _showChallengeBanner = false" title="Dismiss">
                    <i class="bi bi-x"></i>
                </button>
            </div>
        }

        @* Daily Challenge collapsible panel — top-right corner *@
        <div class="daily-panel" @onclick:stopPropagation="true">
            <button class="daily-panel-toggle" @onclick="ToggleDailyPanel" title="Daily Challenges">
                <i class="fas fa-calendar-day"></i>
                <span class="daily-panel-label">Daily Challenges</span>
                <i class="fas fa-chevron-down daily-panel-chevron" style="@(_dailyPanelExpanded ? "transform:rotate(180deg)" : "")"></i>
            </button>
            <div class="daily-panel-body" style="@(_dailyPanelExpanded ? "" : "display:none")">
                <div class="daily-panel-loading" style="@(_dailyLoading ? "" : "display:none")">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                </div>
                <div style="@(!_dailyLoading ? "" : "display:none")">
                    @foreach (var task in _dailyProgress?.Tasks ?? new())
                    {
                        <div class="daily-task-item @(task.Completed ? "daily-task-done" : "")">
                            <span class="daily-task-icon">@task.GetIcon()</span>
                            <span class="daily-task-desc">@task.GetDescription()</span>
                            <i class="bi bi-check-circle-fill daily-task-check" style="@(task.Completed ? "" : "display:none")"></i>
                            <i class="bi bi-circle daily-task-check daily-task-check--empty" style="@(!task.Completed ? "" : "display:none")"></i>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Stack: frenzy label (when active) + ass image *@
        <div class="game-content-stack">
            @if (gamePlaying && frenzyActive)
            {
                <div class="frenzy-above-image @(frenzyChainLevel >= 2 ? "frenzy-chaining" : "")">
                    <div class="frenzy-top-row">
                        <span class="frenzy-title">🔥 FRENZY!</span>
                        @if (frenzyChainLevel >= 2)
                        {
                            <span class="frenzy-chain-badge" @key="frenzyChainLevel">X@(frenzyChainLevel)</span>
                        }
                        <span class="frenzy-hold-hint">HOLD</span>
                    </div>
                    <span class="frenzy-timer">@frenzySecondsLeft</span>
                </div>
            }
            <button class="game-player-card @(!string.IsNullOrWhiteSpace(_currentPlayerName) ? "game-player-card--named" : "")"
                    @onclick:stopPropagation="true"
                    @onclick="ShowPlayerNameDialog">
                <span class="game-player-card-name">
                    <i class="fas @(string.IsNullOrWhiteSpace(_currentPlayerName) ? "fa-user-plus" : "fa-user")"></i>
                    @(string.IsNullOrWhiteSpace(_currentPlayerName) ? "Set Your Name" : _currentPlayerName)
                </span>
                <span class="game-player-card-pb" style="@(_personalBestScore.HasValue ? "" : "display:none")">
                    Personal Best: @((int)(_personalBestScore ?? 0))
                </span>
            </button>
            
            <AssImageDisplay piecesEaten="@piecesEaten" AssFrames="@AssFrames" CurrentAssType="@CurrentAssType" />
        </div>

        @* Timer — top-center, always visible while game is active *@
        @if (gamePlaying)
        {
            <div class="canvas-timer @(gameStartTransition ? "canvas-timer-enter" : "") @(GameTimeInSeconds <= 10 && GameTimeInSeconds > 0 ? "canvas-timer-warning" : "")">
                @TimerDisplay
            </div>
        }

        @* CPS — bottom-right corner during game *@
        @if (gamePlaying)
        {
            var elapsed = DateTime.Now - gameStartTime;
            if (elapsed.TotalSeconds >= 1.0)
            {
                <div class="canvas-cps">
                    <i class="fas fa-mouse"></i> @CurrentClicksPerSecond <small>cps</small>
                </div>
            }
        }

        @* Pre-game prompt (stays mounted during transition so it can animate out) *@
        @if ((!gamePlaying && assesEaten == 0) || gameStartTransition)
        {
            <div class="canvas-hint @(gameStartTransition ? "canvas-hint-exit" : "")">Click to start!</div>
        }

        @* Post-game full overlay — always mounted, toggled via display:none for DOM stability *@
        <div class="canvas-results" style="@(!gamePlaying && assesEaten > 0 ? "" : "display:none")"
             @onclick:stopPropagation="true">

            <div class="go-score-block">
                <div class="go-score-num">@((int)Math.Truncate(assesEaten))</div>
                <div class="go-score-lbl">Asses Devoured</div>
                <div class="go-pb-badge" style="@(_isPersonalBest ? "" : "display:none")">
                    <i class="bi bi-stars"></i> Personal Best!
                </div>
                <div class="go-prev-best" style="@(!_isPersonalBest && _personalBestScore.HasValue ? "" : "display:none")">
                    Your best: @((int)(_personalBestScore ?? 0))
                </div>
                <div class="go-score-msg" style="@(string.IsNullOrEmpty(scoreText) ? "display:none" : "")">@scoreText</div>
                <div class="go-challenge-win" style="@(_challengeScore > 0 && assesEaten > _challengeScore ? "" : "display:none")">
                    <i class="bi bi-trophy-fill"></i> Beat @_challengerName's @((int)_challengeScore)!
                </div>
                <div class="go-challenge-miss" style="@(_challengeScore > 0 && assesEaten <= _challengeScore ? "" : "display:none")">
                    <i class="bi bi-trophy"></i> @_challengerName challenged: beat @((int)_challengeScore)
                </div>
            </div>

            <div class="go-stats-row">
                <div class="go-stat">
                    <span class="go-stat-val">@totalClicks</span>
                    <span class="go-stat-lbl">Clicks</span>
                </div>
                <div class="go-stat-div"></div>
                <div class="go-stat">
                    <span class="go-stat-val">@(clicksPerSecondPolls.Any() ? Math.Round(clicksPerSecondPolls.Average(p => p.clicksPerSecond), 1) : 0)</span>
                    <span class="go-stat-lbl">CPS</span>
                </div>
                <div class="go-stat-div"></div>
                <div class="go-stat">
                    <span class="go-stat-val">@(clicksPerSecondPolls.Any() ? Math.Round(clicksPerSecondPolls.Average(p => p.clicksPerSecond) * 60, 1) : 0)</span>
                    <span class="go-stat-lbl">CPM</span>
                </div>
            </div>

            <div class="go-actions">
                <div class="go-save-slot">
                    <button class="go-btn go-btn-saved" disabled style="@(hasScoreSaved ? "" : "display:none")">
                        <i class="bi bi-check-lg"></i> Saved
                    </button>
                    <button class="go-btn go-btn-primary" @onclick="ShowSaveScoreDialog"
                            disabled="@(_personalBestScore.HasValue && assesEaten <= _personalBestScore.Value)"
                            style="@(!hasScoreSaved ? "" : "display:none")">
                        <i class="bi bi-floppy"></i> Save Score
                    </button>
                </div>
                <button class="go-btn go-btn-challenge" @onclick="CopyGameOverChallengeLink">
                    <i class="bi bi-check-lg" style="@(_gameOverChallengeCopied ? "" : "display:none")"></i>
                    <i class="bi bi-share" style="@(!_gameOverChallengeCopied ? "" : "display:none")"></i>
                    <span>@(_gameOverChallengeCopied ? "Copied!" : "Challenge")</span>
                </button>
                <button class="go-btn go-btn-ghost" @onclick:stopPropagation="true" @onclick="StartNewGame">
                    <i class="fas fa-rotate"></i> Play Again
                </button>
                <button class="go-btn go-btn-ghost" @onclick="() => ResultsDialog?.Modal?.Show()">
                    <i class="fas fa-chart-bar"></i> Details
                </button>
            </div>

        </div>

    </main>

</div>

@* Fire border GIFs — fixed overlay, outside app-shell to avoid overflow clipping *@
@if (gamePlaying && frenzyActive)
{
    <div class="fire-border-overlay" aria-hidden="true">
        <img src="/images/fire-border.gif" class="fire-border-top" alt="" />
        <img src="/images/fire-border.gif" class="fire-border-bottom" alt="" />
        <img src="/images/fire-border.gif" class="fire-border-left" alt="" />
        <img src="/images/fire-border.gif" class="fire-border-right" alt="" />
    </div>
}

<HelpModal @ref="HelpDialog" OnOpenAssDex="OpenAssDexFromHelp" OnNameSaved="OnPlayerNameChanged" CurrentName="@_currentPlayerName" />
<AboutModal @ref="AboutDialog" />
<AnniversaryModal @ref="AnniversaryDialog" />
<UpdateModal @ref="UpdateDialog" />
<AssdexModal @ref="AssdexDialog" OnShowDetail="OpenAssDetail" />
<AssDetailModal @ref="AssDetailDialog" />
<DailyModal @ref="DailyDialog" />
<ResultsModal @ref="ResultsDialog"
              assesEaten="@assesEaten"
              totalClicks="@totalClicks"
              scoreText="@scoreText"
              AssTypes="@Breakdown.Keys.ToList()"
              Breakdown="@Breakdown"
              hasScoreSaved="@hasScoreSaved"
              IsPersonalBest="@_isPersonalBest"
              PersonalBestScore="@_personalBestScore"
              clicksPerSecondPolls="@clicksPerSecondPolls"
              peakComboCount="@frenzyCount"
              PeakChainLevel="@_peakChainLevel"
              CurrentPlayerName="@_currentPlayerName"
              ChallengeScore="@_challengeScore"
              ChallengerName="@_challengerName"
              OnTryAgain="TryAgain"
              OnSaveScore="ShowSaveScoreDialog"
              OnShowLeaderboard="ShowLeaderboardDialog"
              OnShowAssdex="OpenAssdexForType" />
<LeaderboardStatsModal @ref="LeaderboardStatsDialog" />
<SaveScoreModal @ref="SaveScoreDialog" OnScoreSaved="OnScoreSaved" />
<PlayerNameModal @ref="PlayerNameDialog" OnNameSaved="OnPlayerNameChanged" />

@code {
    LeaderboardStatsModal? LeaderboardStatsDialog;
    SaveScoreModal? SaveScoreDialog;
    PlayerNameModal? PlayerNameDialog;
    AssdexModal? AssdexDialog;
    AssDetailModal? AssDetailDialog;
    DailyModal? DailyDialog;

    string _currentPlayerName = string.Empty;
    bool _isPersonalBest = false;
    double? _personalBestScore = null;

    // Challenge state (populated from URL query params)
    double _challengeScore = 0;
    string _challengerName = string.Empty;
    bool _showChallengeBanner = false;

    // Make totalClicks accessible in the template
    public int totalClicks = 0;

    async Task ShowPlayerNameDialog()
    {
        if (PlayerNameDialog != null) await PlayerNameDialog.Show();
    }

    async Task ShowLeaderboardDialog()
    {
        if (LeaderboardStatsDialog != null) await LeaderboardStatsDialog.ShowLeaderboard();
    }

    async Task ShowLeaderboardStatsDialog()
    {
        if (LeaderboardStatsDialog != null) await LeaderboardStatsDialog.ShowLeaderboard();
    }

    async Task ShowAssdexDialog()
    {
        await AssdexDialog?.Show();
    }

    async Task OpenAssDetail(AssTypeEnum assType)
    {
        await AssDetailDialog?.ShowAsync(assType);
    }

    async Task OpenAssdexForType(AssTypeEnum assType)
    {
        await ResultsDialog?.Modal?.Hide();
        await AssdexDialog?.ShowForType(assType);
    }

    async Task ShowDailyDialog()
    {
        await DailyDialog?.Show();
    }

    async Task ShowSaveScoreDialog()
    {
        if (!hasScoreSaved)
        {
            await SaveScoreDialog?.Show(assesEaten, totalClicks, Breakdown);
        }
    }

    async Task OnScoreSaved()
    {
        hasScoreSaved = true;
        _currentPlayerName = await SettingsService.GetLastPlayerNameAsync() ?? string.Empty;
        StateHasChanged();
    }

    bool _gameOverChallengeCopied = false;

    void OnPlayerNameChanged(string name)
    {
        _currentPlayerName = name;
        HelpDialog?.NotifyNameSaved(name);
        StateHasChanged();
    }

    async Task CopyGameOverChallengeLink()
    {
        var score = (int)Math.Truncate(assesEaten);
        var name = string.IsNullOrWhiteSpace(_currentPlayerName) ? "Someone" : _currentPlayerName.Trim();
        var url = $"{NavigationManager.BaseUri}?challenge={score}&challenger={Uri.EscapeDataString(name)}";
        await js.InvokeVoidAsync("copyToClipboard", url);
        _gameOverChallengeCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _gameOverChallengeCopied = false;
        StateHasChanged();
    }
}
