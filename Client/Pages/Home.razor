@page "/"
@using BlazorApp.Client.Components
@using BlazorApp.Client.Services
@inject IJSRuntime js
@inject ILeaderboardService LeaderboardService
@inject ISettingsService SettingsService
@inject IVersionCheckService VersionCheckService
@inject IStatsService StatsService
@inject ICollectionService CollectionService
@inject IDailyChallengeService DailyChallengeService

<PageTitle>Eat my entire ass</PageTitle>

<div class="app-shell">

    <header class="app-bar">
        <div class="app-bar-brand">
            <img src="/icon-192.png" alt="EMEA" width="28" class="app-bar-icon" />
            <span class="app-bar-title">EMEA</span>
        </div>

        <nav class="app-bar-actions">
            <button class="icon-btn" @onclick="ShowHelpDialog" title="How to Play">
                <i class="fas fa-book-open"></i>
            </button>
            <button class="icon-btn" @onclick="ShowLeaderboardStatsDialog" title="Leaderboard &amp; Stats">
                <i class="fas fa-trophy"></i>
            </button>
            <button class="icon-btn" @onclick="ShowAssdexDialog" title="Assdex">
                <i class="fas fa-book"></i>
            </button>
            <button class="icon-btn" @onclick="ShowDailyDialog" title="Daily Challenge">
                <i class="fas fa-calendar-day"></i>
            </button>
        </nav>

        <div class="app-bar-end">
            <button class="icon-btn @(playSounds ? "icon-btn-active" : "")" @onclick="ToggleSound"
                    title="@(playSounds ? "Sound On" : "Sound Off")">
                <i class="@(playSounds ? "fas fa-volume-up" : "fas fa-volume-mute")"></i>
            </button>
            <a href="https://github.com/jwp528/eatmyentireass.online" target="_blank"
               rel="noopener noreferrer" class="icon-btn hide-xs" title="View Source Code">
                <i class="fab fa-github"></i>
            </a>
            <button class="icon-btn" @onclick="ShowAboutDialog" title="About Developer">
                <img src="https://www.joshparsons.ca/img/Logo.svg" alt="Josh Parsons"
                     width="18" height="18" class="icon-btn-img" />
            </button>
        </div>
    </header>

    <main class="game-main" @onclick="EatPiece" role="button" tabindex="0">
        <AssImageDisplay piecesEaten="@piecesEaten" AssFrames="@AssFrames" CurrentAssType="@CurrentAssType" />

        @if (gamePlaying && comboCount >= 3)
        {
            <div class="combo-badge @ComboCssClass">
                <span class="combo-x">×@ComboMultiplier.ToString("G2")</span>
                <span class="combo-label">@ComboLabel</span>
            </div>
        }
    </main>

    <footer class="status-strip">
        <div class="status-item @(GameTimeInSeconds <= 10 && GameTimeInSeconds > 0 ? "status-warning" : "")">
            <i class="fas fa-clock status-icon"></i>
            <span class="status-timer-val">@TimerDisplay</span>
        </div>

        <div class="status-center">
            @if (!gamePlaying)
            {
                @if (assesEaten > 0)
                {
                    <span class="status-score">@Math.Truncate(assesEaten) pts</span>
                    <button class="status-action-btn" @onclick="() => ResultsDialog?.Modal?.Show()">
                        <i class="fas fa-chart-bar"></i><span class="btn-label"> Details</span>
                    </button>
                    <button class="status-action-btn status-action-primary" @onclick="StartNewGame">
                        <i class="fas fa-rotate"></i><span class="btn-label"> Play Again</span>
                    </button>
                }
                else
                {
                    <span class="status-hint">Click to start!</span>
                }
            }
            else
            {
                <span class="status-hint">CONSUME!</span>
            }
        </div>

        <div class="status-item status-cps-area">
            @if (gamePlaying)
            {
                var elapsed = DateTime.Now - gameStartTime;
                @if (elapsed.TotalSeconds >= 1.0)
                {
                    <i class="fas fa-mouse status-icon"></i>
                    <span class="status-cps-val">@CurrentClicksPerSecond</span>
                    <small class="status-cps-label">cps</small>
                }
            }
        </div>
    </footer>

</div>

<HelpModal @ref="HelpDialog" CarouselItems="@CarouselItems" />
<AboutModal @ref="AboutDialog" />
<AnniversaryModal @ref="AnniversaryDialog" />
<UpdateModal @ref="UpdateDialog" />
<AssdexModal @ref="AssdexDialog" />
<DailyModal @ref="DailyDialog" />
<ResultsModal @ref="ResultsDialog"
              assesEaten="@assesEaten"
              totalClicks="@totalClicks"
              scoreText="@scoreText"
              AssTypes="@Breakdown.Keys.ToList()"
              Breakdown="@Breakdown"
              hasScoreSaved="@hasScoreSaved"
              clicksPerSecondPolls="@clicksPerSecondPolls"
              peakComboCount="@peakComboCount"
              OnTryAgain="TryAgain"
              OnSaveScore="ShowSaveScoreDialog"
              OnShowLeaderboard="ShowLeaderboardDialog" />
<LeaderboardStatsModal @ref="LeaderboardStatsDialog" />
<SaveScoreModal @ref="SaveScoreDialog" OnScoreSaved="OnScoreSaved" />

@code {
    LeaderboardStatsModal? LeaderboardStatsDialog;
    SaveScoreModal? SaveScoreDialog;
    AssdexModal? AssdexDialog;
    DailyModal? DailyDialog;

    // Make totalClicks accessible in the template
    public int totalClicks = 0;

    async Task ShowLeaderboardDialog()
    {
        if (LeaderboardStatsDialog != null) await LeaderboardStatsDialog.ShowLeaderboard();
    }

    async Task ShowLeaderboardStatsDialog()
    {
        if (LeaderboardStatsDialog != null) await LeaderboardStatsDialog.ShowLeaderboard();
    }

    async Task ShowAssdexDialog()
    {
        await AssdexDialog?.Show();
    }

    async Task ShowDailyDialog()
    {
        await DailyDialog?.Show();
    }

    async Task ShowSaveScoreDialog()
    {
        if (!hasScoreSaved)
        {
            await SaveScoreDialog?.Show(assesEaten, totalClicks, Breakdown);
        }
    }

    async Task OnScoreSaved()
    {
        hasScoreSaved = true;
        StateHasChanged();
    }
}
