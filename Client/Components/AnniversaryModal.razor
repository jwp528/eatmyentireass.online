@inject IJSRuntime JS
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

@code {
    public BSModal? Modal;

    public async Task ShowIfEligibleAsync()
    {
        var alreadySeen = await LocalStorage.GetItemAsync<bool>("anniversaryModalSeen_2026");
        if (alreadySeen) return;

        var today = DateTime.Today;
        var windowStart = new DateTime(2026, 5, 18);
        var windowEnd = new DateTime(2026, 5, 28);
        if (today < windowStart || today > windowEnd) return;

        await Task.Delay(600);
        await Modal!.Show();
        await JS.InvokeVoidAsync("fireConfetti");
    }

    private async Task Dismiss()
    {
        await LocalStorage.SetItemAsync("anniversaryModalSeen_2026", true);
        await Modal!.Hide();
    }
}

<BSModal @ref="Modal" Id="anniversaryModal" IsVerticallyCentered="true" Size="ModalSize.Large">
    <Body>
        <div class="av-shell">
            <div class="av-tag">One Year</div>
            <div class="av-header-row">
                <img src="images/Asses/Cartoon/entire_ass.png" class="av-ass-img" alt="cartoon ass" />
                <div>
                    <h2 class="av-title">An Entire Year of Eating Ass</h2>
                    <div class="av-date">May 21, 2025 — May 21, 2026</div>
                </div>
            </div>

            <div class="av-divider"></div>

            <p class="av-lead">365 days. Countless asses consumed.</p>
            <p class="av-body">
                To every person who clicked, munched, and devoured their way through the leaderboard —
                thank you. This ridiculous corner of the internet exists because of your continued
                dedication to the craft of ass-eating.
            </p>
            <p class="av-body">
                You could have spent your time productively. You chose this instead.
                That is beautiful. That is <em>commitment</em>.
            </p>

            <div class="av-actions">
                <button type="button" class="av-btn" @onclick="Dismiss">Let's Eat</button>
            </div>
        </div>
    </Body>
</BSModal>
