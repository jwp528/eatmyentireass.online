@using BlazorApp.Client.Components.BootstrapCarousel
@using BlazorApp.Client.Components.Svg

<BSModal @ref="Modal" Id="helpModal" IsVerticallyCentered="true" Size="ModalSize.Large">
    <Body>
        <div class="hp-shell">
            <div class="hp-header">
                <i class="fas fa-gamepad hp-title-icon"></i>
                <span class="hp-title">How to Play</span>
            </div>

            <div class="hp-tabbar">
                <button class="hp-tab @(_tab == 0 ? "hp-tab--on" : "")" @onclick="@(() => _tab = 0)">
                    <i class="fas fa-gamepad"></i> Basics
                </button>
                <button class="hp-tab @(_tab == 1 ? "hp-tab--on" : "")" @onclick="@(() => _tab = 1)">
                    <Assdex Size="1em" Color="@(_tab == 1 ? "#7986cb" : "rgba(255,255,255,0.4)")" Style="Assdex.AssdexIconStyle.Outline" />
                    AssDex
                </button>
                <button class="hp-tab @(_tab == 2 ? "hp-tab--on" : "")" @onclick="@(() => _tab = 2)">
                    <i class="fas fa-lightbulb"></i> Tips
                </button>
            </div>

            @if (_tab == 0)
            {
                <div class="hp-panel">
                    <p class="hp-label">Steps</p>
                    <ol class="hp-steps">
                        <li>Click the ass to start the 60-second timer</li>
                        <li>Keep clicking to devour each ass completely</li>
                        <li>Finish eating to score points and get a new ass</li>
                    </ol>

                    <div class="hp-divider"></div>

                    <p class="hp-label">Scoring</p>
                    <div class="hp-list">
                        <div class="hp-row">
                            <span class="hp-row-name">Complete to Score</span>
                            <span class="hp-row-desc">You must finish eating an ass completely to earn points. Partial asses don't count.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Click Efficiency</span>
                            <span class="hp-row-desc">Every click counts toward your efficiency rating, even on incomplete asses.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Final Score</span>
                            <span class="hp-row-desc">Scores round down to whole numbers. No participation awards.</span>
                        </div>
                    </div>

                    <div class="hp-divider"></div>

                    <p class="hp-label">🔥 Frenzy Mode</p>
                    <div class="hp-list">
                        <div class="hp-row">
                            <span class="hp-row-name">What is it?</span>
                            <span class="hp-row-desc">A 10-second turbo mode that pauses the main timer so every frenzy second is bonus time.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">How it works</span>
                            <span class="hp-row-desc">Hold the ass to auto-eat at 10 bites per second. Fire borders erupt and the screen shakes — you'll know.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Why you want it</span>
                            <span class="hp-row-desc">The clock stops and you eat for free. Chain multiple frenzies for a monster score.</span>
                        </div>
                    </div>
                </div>
            }

            @if (_tab == 1)
            {
                <div class="hp-panel hp-dex-panel">
                    <div class="hp-dex-hero">
                        <Assdex Size="44px" Color="#7986cb" Style="Assdex.AssdexIconStyle.Fill" />
                        <div>
                            <p class="hp-dex-name">AssDex</p>
                            <p class="hp-dex-tagline">Your personal catalog of every ass you've encountered.</p>
                        </div>
                    </div>

                    <div class="hp-divider"></div>

                    <p class="hp-label">How it works</p>
                    <div class="hp-list">
                        <div class="hp-row">
                            <span class="hp-row-name">Discover</span>
                            <span class="hp-row-desc">Each ass type you eat for the first time is permanently unlocked in your AssDex.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Progress</span>
                            <span class="hp-row-desc">Track how many of each ass you've fully eaten and your personal records.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Details</span>
                            <span class="hp-row-desc">Tap any entry to see its full stats, point value, rarity, and completion history.</span>
                        </div>
                    </div>

                    <div class="hp-dex-action">
                        <button type="button" class="hp-btn hp-btn-icon" @onclick="HandleOpenAssDex">
                            <Assdex Size="1em" Color="#fff" Style="Assdex.AssdexIconStyle.Outline" />
                            Open
                        </button>
                    </div>
                </div>
            }

            @if (_tab == 2)
            {
                <div class="hp-panel">
                    <p class="hp-label">Pro Tips</p>
                    <div class="hp-list">
                        <div class="hp-row">
                            <span class="hp-row-name">Speed is Key</span>
                            <span class="hp-row-desc">Click rapidly to maximize your score.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Golden Opportunity</span>
                            <span class="hp-row-desc">Golden asses are rare (~2% chance), worth the most points, and instantly trigger Frenzy mode.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Efficiency Matters</span>
                            <span class="hp-row-desc">Your click efficiency is tracked — make every click count.</span>
                        </div>
                    </div>
                </div>
            }

            <div class="hp-footer">
                <button type="button" class="hp-btn" @onclick="async () => await Modal?.Hide()">Let's Play</button>
            </div>
        </div>
    </Body>
</BSModal>

@code {
    [Parameter] public List<CarouselItem> CarouselItems { get; set; } = new();
    [Parameter] public EventCallback OnOpenAssDex { get; set; }
    public BSModal? Modal;
    private int _tab = 0;

    private async Task HandleOpenAssDex()
    {
        await Modal!.Hide();
        await OnOpenAssDex.InvokeAsync();
    }

    private double GetPointValue(string description)
    {
        if (description.StartsWith("10 point")) return 10;
        if (description.StartsWith("2 point")) return 2;
        if (description.StartsWith("1 point")) return 1;
        if (description.StartsWith("0.5 point")) return 0.5;
        return 1;
    }
}
