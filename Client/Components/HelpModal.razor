@using BlazorApp.Client.Components.BootstrapCarousel
@using BlazorApp.Client.Components.Svg

<BSModal @ref="Modal" Id="helpModal" IsVerticallyCentered="true" Size="ModalSize.Large">
    <Body>
        <div class="hp-shell">
            <div class="hp-header">
                <i class="fas fa-gamepad hp-title-icon"></i>
                <span class="hp-title">How to Play</span>
            </div>

            <div class="hp-tabbar">
                <button class="hp-tab @(_tab == 0 ? "hp-tab--on" : "")" @onclick="@(() => _tab = 0)">
                    <i class="fas fa-gamepad"></i> Basics
                </button>
                <button class="hp-tab @(_tab == 1 ? "hp-tab--on" : "")" @onclick="@(() => _tab = 1)">
                    <Assdex Size="1em" Color="@(_tab == 1 ? "#7986cb" : "rgba(255,255,255,0.4)")" Style="Assdex.AssdexIconStyle.Outline" />
                    AssDex
                </button>
            </div>

            @if (_tab == 0)
            {
                <div class="hp-panel">
                    <p class="hp-tagline">Tap fast. Eat ass. Beat everyone.</p>

                    <p class="hp-label">How to Play</p>
                    <ol class="hp-steps">
                        <li>Click the ass to start the 60-second timer</li>
                        <li>Keep clicking to eat each ass completely</li>
                        <li>Finish eating to score points and get a new ass</li>
                        <li>The more you eat, the higher your score — compete with friends!</li>
                    </ol>

                    <div class="hp-divider"></div>

                    <p class="hp-label">Scoring</p>
                    <div class="hp-list">
                        <div class="hp-row">
                            <span class="hp-row-name">Finish to Score</span>
                            <span class="hp-row-desc">You must fully eat an ass to earn its points. Partial asses don't count.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Ass Rarity</span>
                            <span class="hp-row-desc">Different ass types are worth different points. Rarer asses = more points.</span>
                        </div>
                    </div>

                    <div class="hp-divider"></div>

                    <p class="hp-label">🔥 Frenzy Mode</p>
                    <div class="hp-list">
                        <div class="hp-row">
                            <span class="hp-row-name">Find the Golden Ass</span>
                            <span class="hp-row-desc">Eat a rare Golden Ass to trigger Frenzy Mode — a 10-second turbo boost where you hold to auto-eat at hyperspeed.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Frenzy Chain</span>
                            <span class="hp-row-desc">Eat a Golden Ass <em>while already in Frenzy</em> to start a Frenzy Chain. Every chained frenzy multiplies your score (×2, ×3, ×4…).</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Chain More, Score More</span>
                            <span class="hp-row-desc">Keep finding Golden Asses during Frenzy to push the multiplier higher. The bigger the chain, the bigger the score.</span>
                        </div>
                    </div>
                </div>
            }

            @if (_tab == 1)
            {
                <div class="hp-panel hp-dex-panel">
                    <div class="hp-dex-hero">
                        <Assdex Size="44px" Color="#7986cb" Style="Assdex.AssdexIconStyle.Fill" />
                        <div>
                            <p class="hp-dex-name">AssDex</p>
                            <p class="hp-dex-tagline">Your personal catalog of every ass you've encountered.</p>
                        </div>
                    </div>

                    <div class="hp-divider"></div>

                    <p class="hp-label">How it works</p>
                    <div class="hp-list">
                        <div class="hp-row">
                            <span class="hp-row-name">Discover</span>
                            <span class="hp-row-desc">Each ass type you eat for the first time is permanently unlocked in your AssDex.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Progress</span>
                            <span class="hp-row-desc">Track how many of each ass you've fully eaten and your personal records.</span>
                        </div>
                        <div class="hp-row">
                            <span class="hp-row-name">Details</span>
                            <span class="hp-row-desc">Tap any entry to see its full stats, point value, rarity, and completion history.</span>
                        </div>
                    </div>

                    <div class="hp-dex-action">
                        <button type="button" class="hp-btn hp-btn-icon" @onclick="HandleOpenAssDex">
                            <Assdex Size="1em" Color="#fff" Style="Assdex.AssdexIconStyle.Outline" />
                            Open
                        </button>
                    </div>
                </div>
            }

            <div class="hp-footer">
                <button type="button" class="hp-btn" @onclick="async () => await Modal?.Hide()">Let's Play</button>
            </div>
        </div>
    </Body>
</BSModal>

@code {
    [Parameter] public List<CarouselItem> CarouselItems { get; set; } = new();
    [Parameter] public EventCallback OnOpenAssDex { get; set; }
    public BSModal? Modal;
    private int _tab = 0;

    private async Task HandleOpenAssDex()
    {
        await Modal!.Hide();
        await OnOpenAssDex.InvokeAsync();
    }

    private double GetPointValue(string description)
    {
        if (description.StartsWith("10 point")) return 10;
        if (description.StartsWith("2 point")) return 2;
        if (description.StartsWith("1 point")) return 1;
        if (description.StartsWith("0.5 point")) return 0.5;
        return 1;
    }
}
