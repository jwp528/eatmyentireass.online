@using BlazorApp.Client.Components.Svg
@inject BlazorApp.Client.Services.ISettingsService SettingsService

<BSModal @ref="Modal" Id="helpModal" IsVerticallyCentered="true" Size="ModalSize.Large">
    <Body>
        <div class="hp-shell">

            @* Step dots *@
            <div class="hp-dots">
                @for (int i = 0; i < TotalSteps; i++)
                {
                    int idx = i;
                    <button class="hp-dot @(_step == idx ? "hp-dot--on" : "")"
                            @onclick="() => _step = idx"
                            title="Step @(idx + 1)" />
                }
            </div>

            @* ── Step 1: Welcome ─────────────────────────────────────────── *@
            <div class="hp-step" style="@(_step == 0 ? "" : "display:none")">
                <div class="hp-welcome">
                    <img src="images/Asses/Golden/entire_ass.png" class="hp-welcome-img" alt="Golden Ass" />
                    <h2 class="hp-welcome-title">Eat My Entire Ass</h2>
                    <p class="hp-tagline">Tap fast. Eat ass. Beat everyone.</p>
                    <p class="hp-welcome-sub">A 60-second feeding frenzy of questionable choices. Can you out-eat your friends?</p>
                </div>
            </div>

            @* ── Step 2: How to Play ──────────────────────────────────────── *@
            <div class="hp-step" style="@(_step == 1 ? "" : "display:none")">
                <p class="hp-step-title">How to Play</p>

                <ol class="hp-steps">
                    <li>Click the ass to start the 60-second timer</li>
                    <li>Keep clicking to eat each ass completely</li>
                    <li>Finish eating to score points and get a new ass</li>
                    <li>The more you eat, the higher your score!</li>
                </ol>

                <div class="hp-divider"></div>

                <p class="hp-label">Scoring</p>
                <div class="hp-list">
                    <div class="hp-row">
                        <span class="hp-row-name">Finish to Score</span>
                        <span class="hp-row-desc">You must fully eat an ass to earn its points. Partial asses don't count.</span>
                    </div>
                    <div class="hp-row">
                        <span class="hp-row-name">Ass Rarity</span>
                        <span class="hp-row-desc">Different ass types are worth different points. Rarer asses = more points.</span>
                    </div>
                </div>
            </div>

            @* ── Step 3: Frenzy Mode ──────────────────────────────────────── *@
            <div class="hp-step" style="@(_step == 2 ? "" : "display:none")">
                <p class="hp-step-title">🔥 Frenzy Mode</p>

                <div class="hp-list">
                    <div class="hp-row">
                        <span class="hp-row-name">Find the Golden Ass</span>
                        <span class="hp-row-desc">Eat a rare Golden Ass to trigger Frenzy Mode — a 10-second turbo boost where you hold to auto-eat at hyperspeed.</span>
                    </div>
                    <div class="hp-row">
                        <span class="hp-row-name">Frenzy Chain</span>
                        <span class="hp-row-desc">Eat a Golden Ass <em>while already in Frenzy</em> to start a Frenzy Chain. Every chained frenzy multiplies your score (×2, ×3, ×4…).</span>
                    </div>
                    <div class="hp-row">
                        <span class="hp-row-name">Chain More, Score More</span>
                        <span class="hp-row-desc">Keep finding Golden Asses during Frenzy to push the multiplier higher. The bigger the chain, the bigger the score.</span>
                    </div>
                </div>
            </div>

            @* ── Step 4: Your Name ────────────────────────────────────────── *@
            <div class="hp-step" style="@(_step == 3 ? "" : "display:none")">
                <p class="hp-step-title">Who Are You?</p>
                <p class="hp-step-sub">Your name appears on the global leaderboard. Optional, but way more fun.</p>

                <div class="hp-name-block">
                    @if (!string.IsNullOrWhiteSpace(_displayName))
                    {
                        <div class="hp-name-set">
                            <i class="bi bi-person-check-fill hp-name-check"></i>
                            <span class="hp-name-value">@_displayName</span>
                        </div>
                        <button type="button" class="hp-btn hp-btn-ghost hp-name-change-btn"
                                @onclick="RequestSetName">Change</button>
                    }
                    else
                    {
                        <button type="button" class="hp-btn hp-name-set-btn"
                                @onclick="RequestSetName">
                            <i class="bi bi-person-plus"></i> Set Your Name
                        </button>
                    }
                </div>

                <button type="button" class="hp-skip-link" @onclick="() => _step = 4">
                    Skip for now
                </button>
            </div>

            @* ── Step 5: Let's Play! ──────────────────────────────────────── *@
            <div class="hp-step hp-step--final" style="@(_step == 4 ? "" : "display:none")">
                <div class="hp-ready">
                    <div class="hp-ready-icon">🍑</div>
                    <h2 class="hp-ready-title">You're Ready.</h2>
                    @if (!string.IsNullOrWhiteSpace(_displayName))
                    {
                        <p class="hp-ready-sub">Good luck, <strong>@_displayName</strong>. Try not to choke.</p>
                    }
                    else
                    {
                        <p class="hp-ready-sub">Go eat some ass. You've earned it.</p>
                    }
                    <button type="button" class="hp-btn hp-btn-play" @onclick="Close">
                        Let's Play!
                    </button>
                </div>
            </div>

            @* ── Navigation ──────────────────────────────────────────────── *@
            <div class="hp-nav">
                <button class="hp-nav-back" style="@(_step > 0 ? "" : "visibility:hidden")"
                        @onclick="() => _step--">
                    <i class="bi bi-arrow-left"></i> Back
                </button>
                <button class="hp-nav-next" style="@(_step < TotalSteps - 1 ? "" : "display:none")"
                        @onclick="() => _step++">
                    Next <i class="bi bi-arrow-right"></i>
                </button>
            </div>

        </div>
    </Body>
</BSModal>

@code {
    [Parameter] public EventCallback OnOpenAssDex { get; set; }
    [Parameter] public EventCallback OnSetNameRequested { get; set; }
    [Parameter] public string CurrentName { get; set; } = string.Empty;

    public BSModal? Modal;

    private const int TotalSteps = 5;
    private int _step = 0;
    private string _displayName = string.Empty;

    protected override void OnParametersSet()
    {
        if (string.IsNullOrWhiteSpace(_displayName))
            _displayName = CurrentName ?? string.Empty;
    }

    // Called by Home when the game first renders or after a name is saved
    public void ShowIntro()
    {
        _step = 0;
        _displayName = CurrentName ?? string.Empty;
        Modal?.Show();
    }

    // Called by Home after PlayerNameModal fires OnNameSaved
    public void NotifyNameSaved(string name)
    {
        _displayName = name;
        // Auto-advance past the name step
        if (_step == 3) _step = 4;
        InvokeAsync(StateHasChanged);
    }

    private async Task RequestSetName()
    {
        if (OnSetNameRequested.HasDelegate)
            await OnSetNameRequested.InvokeAsync();
    }

    private async Task Close()
    {
        await Modal?.Hide();
    }
}
