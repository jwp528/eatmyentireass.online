@using BlazorApp.Shared

<BSModal @ref="Modal" Id="statsModal" IsVerticallyCentered="true" Size="ModalSize.Large">
    <Body>
        <div class="sm-shell">
            <div class="sm-header">
                <div class="sm-title">
                    <i class="bi bi-bar-chart-line-fill sm-title-icon"></i>
                    Global Stats
                </div>
                <p class="sm-subtitle">Aggregated across all players worldwide</p>
            </div>

            <div class="sm-body">
                <GlobalStatsPanel Stats="@stats" IsLoading="@isLoading" />
            </div>

            <div class="sm-actions">
                <button type="button" class="sm-btn sm-btn-ghost" @onclick="LoadStats" disabled="@isLoading">
                    <i class="bi bi-arrow-clockwise"></i> Refresh
                </button>
                <button type="button" class="sm-btn sm-btn-primary" @onclick="() => Modal?.Hide()">
                    <i class="bi bi-x-lg"></i> Close
                </button>
            </div>
        </div>
    </Body>
</BSModal>
