@using BlazorApp.Shared

<BSModal @ref="Modal" Id="saveScoreModal" IsVerticallyCentered="true">
    <Body>
        <div class="ss-shell">

            <!-- Header -->
            <div class="ss-header">
                <div class="ss-tag @(isHighScore ? "" : "ss-tag-dim")">
                    @(isHighScore ? "High Score" : "Save Score")
                </div>
                <div class="ss-score">@((int)Math.Truncate(Score))</div>
                <div class="ss-meta">
                    <span>@TotalClicks clicks</span>
                    <span class="ss-dot">·</span>
                    <span>@(TotalClicks > 0 ? Math.Round(Score / TotalClicks, 3) : 0) pts/click</span>
                    @if (isHighScore && playerRank > 0)
                    {
                        <span class="ss-dot">·</span>
                        <span class="ss-rank-chip">Rank #@playerRank</span>
                    }
                </div>
            </div>

            <div class="ss-divider"></div>

            <!-- Name field -->
            <div class="ss-field">
                <label for="playerName">Player Name</label>
                <div class="ss-input-row">
                    <input type="text"
                           class="ss-input"
                           id="playerName"
                           value="@playerName"
                           @oninput="OnNameChanged"
                           @onkeypress="HandleKeyPress"
                           placeholder="Enter your name"
                           maxlength="50"
                           disabled="@isSaving" />
                    @if (_nameState == NameState.Checking)
                    {
                        <span class="ss-name-indicator ss-checking">
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                        </span>
                    }
                    else if (_nameState == NameState.ClaimedOwned)
                    {
                        <span class="ss-name-indicator ss-owned" title="Name protected — you own it">
                            <i class="bi bi-shield-check"></i>
                        </span>
                    }
                    else if (_nameState == NameState.ClaimedNotOwned)
                    {
                        <span class="ss-name-indicator ss-locked" title="Name is claimed">
                            <i class="bi bi-lock"></i>
                        </span>
                    }
                </div>

                @if (_nameState == NameState.Free && !_showClaimForm)
                {
                    <button type="button" class="ss-link-btn" @onclick="() => { _showClaimForm = true; StateHasChanged(); }">
                        Claim this name
                    </button>
                }
            </div>

            @if (_nameState == NameState.ClaimedNotOwned && _showPasswordField && !_showClaimForm)
            {
                <div class="ss-field">
                    <label for="namePassword">Password</label>
                    <input type="password"
                           class="ss-input"
                           id="namePassword"
                           @bind="password"
                           @onkeypress="HandleKeyPress"
                           placeholder="Password for this name"
                           disabled="@isSaving" />
                    <span class="ss-caption">This name is claimed. Enter its password to use it.</span>
                </div>
            }

            @if (_showClaimForm)
            {
                <div class="ss-field">
                    <label for="claimPassword">Set Password</label>
                    <input type="password"
                           class="ss-input"
                           id="claimPassword"
                           @bind="password"
                           placeholder="Min 4 characters"
                           disabled="@isSaving" />
                </div>
                <div class="ss-field">
                    <label for="confirmPassword">Confirm Password</label>
                    <input type="password"
                           class="ss-input"
                           id="confirmPassword"
                           @bind="confirmPassword"
                           @onkeypress="HandleKeyPress"
                           placeholder="Repeat password"
                           disabled="@isSaving" />
                    <span class="ss-caption">Claiming locks this name — only you can use it with your password.</span>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="ss-error">@errorMessage</div>
            }

            @if (isSaving)
            {
                <div class="ss-saving">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                    <span>Saving…</span>
                </div>
            }

            <div class="ss-caption">Scores are saved to the global leaderboard and visible to all players.</div>

            <!-- Actions -->
            <div class="ss-actions">
                <button type="button" class="ss-btn-ghost" @onclick="SkipSave" disabled="@isSaving">
                    Skip
                </button>
                <button type="button"
                        class="ss-btn-primary"
                        @onclick="SaveScore"
                        disabled="@(isSaving || string.IsNullOrWhiteSpace(playerName))">
                    @(isSaving ? "Saving…" : _showClaimForm ? "Claim & Save" : "Save Score")
                </button>
            </div>

        </div>
    </Body>
</BSModal>