@using BlazorApp.Shared

<BSModal @ref="Modal" Id="saveScoreModal" IsVerticallyCentered="true">
    <Body>
        <div class="save-score-container">
            <!-- Modal Title -->
            <div class="text-center mb-4">
                @if (isHighScore)
                {
                    <h4 class="fw-bold text-warning mb-0">
                        <i class="fas fa-trophy text-warning me-2"></i>
                        🎉 HIGH SCORE! 🎉
                    </h4>
                    <small class="text-muted">You made it to the top 10!</small>
                }
                else
                {
                    <h4 class="fw-bold text-white mb-0">
                        <i class="fas fa-save text-success me-2"></i>
                        Save Your Score
                    </h4>
                }
            </div>

            <div class="mb-4 text-center">
                <div class="display-6 text-primary fw-bold">@Math.Truncate(Score)</div>
                <div class="text-muted">
                    @TotalClicks clicks • @(TotalClicks > 0 ? Math.Round(Score / TotalClicks, 3) : 0) points/click
                </div>
                @if (isHighScore && playerRank > 0)
                {
                    <div class="badge bg-warning text-dark mt-2">
                        <i class="fas fa-medal me-1"></i>Rank #@playerRank
                    </div>
                }
                <p class="text-muted mb-0 mt-2">
                    @if (isHighScore)
                    {
                        <span class="text-warning">🏆 Congratulations! This score earns a spot on the leaderboard!</span>
                    }
                    else
                    {
                        <span>Great score! Your progress is saved locally.</span>
                    }
                </p>
            </div>
            
            <div class="mb-3">
                <label for="playerName" class="form-label fw-semibold text-white">Player Name</label>
                <input type="text" 
                       class="form-control form-control-lg" 
                       id="playerName" 
                       @bind="playerName" 
                       @onkeypress="HandleKeyPress"
                       placeholder="Enter your name"
                       maxlength="50"
                       disabled="@isSaving">
            </div>
            
            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <div style="white-space: pre-line;">@errorMessage</div>
                </div>
            }
            
            @if (isSaving)
            {
                <div class="text-center mb-3">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Saving...</span>
                    </div>
                    <p class="mt-2 text-muted">Saving to shared global leaderboard...</p>
                </div>
            }

            <!-- Information about shared storage -->
            <div class="alert alert-info mb-3" role="alert">
                <i class="fas fa-info-circle me-2"></i>
                <small>Scores are saved to the global shared leaderboard. All players will see your score immediately!</small>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-between">
                <button type="button" 
                        class="btn btn-outline-secondary" 
                        @onclick="SkipSave"
                        disabled="@isSaving">
                    <i class="fas fa-times me-1"></i>Skip
                </button>
                <button type="button" 
                        class="btn btn-success" 
                        @onclick="SaveScore"
                        disabled="@(isSaving || string.IsNullOrWhiteSpace(playerName))">
                    <i class="fas @(isHighScore ? "fa-trophy" : "fa-save") me-2"></i>
                    @(isSaving ? "Saving..." : isHighScore ? "Save High Score!" : "Save Score")
                </button>
            </div>
        </div>
    </Body>
</BSModal>

<style>
    .save-score-container {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: #ffffff;
        padding: 1.5rem;
        border-radius: 12px;
    }

    .save-score-container .form-control {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #ffffff;
    }

    .save-score-container .form-control:focus {
        background: rgba(255, 255, 255, 0.15);
        border-color: #0d6efd;
        color: #ffffff;
        box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);
    }

    .save-score-container .form-control::placeholder {
        color: rgba(255, 255, 255, 0.6);
    }

    .save-score-container .alert-info {
        background: rgba(13, 202, 240, 0.1);
        border: 1px solid rgba(13, 202, 240, 0.2);
        color: #9ec5fe;
    }
</style>