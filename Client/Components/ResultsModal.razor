@using BlazorApp.Shared
@using static BlazorApp.Shared.Assets
@using BlazorApp.Client.Services
@inject IStatsService StatsService
@inject IJSRuntime Js
@inject NavigationManager Nav

@code {
    [Parameter] public double assesEaten { get; set; }
    [Parameter] public int totalClicks { get; set; }
    [Parameter] public string scoreText { get; set; } = string.Empty;
    [Parameter] public List<AssTypeEnum> AssTypes { get; set; } = new();
    [Parameter] public Dictionary<AssTypeEnum, int> Breakdown { get; set; } = new();
    [Parameter] public bool hasScoreSaved { get; set; }
    [Parameter] public bool IsAutoSaving { get; set; }
    [Parameter] public bool IsPersonalBest { get; set; }
    [Parameter] public double? PersonalBestScore { get; set; }
    [Parameter] public int peakComboCount { get; set; }
    [Parameter] public int PeakChainLevel { get; set; }
    [Parameter] public double GameDurationSeconds { get; set; } = 60;
    [Parameter] public List<(int timeStamp, double clicksPerSecond)> clicksPerSecondPolls { get; set; } = new();
    [Parameter] public EventCallback OnTryAgain { get; set; }
    [Parameter] public EventCallback OnSaveScore { get; set; }
    [Parameter] public EventCallback OnShowLeaderboard { get; set; }
    [Parameter] public EventCallback<AssTypeEnum> OnShowAssdex { get; set; }
    [Parameter] public string CurrentPlayerName { get; set; } = string.Empty;
    [Parameter] public double ChallengeScore { get; set; } = 0;
    [Parameter] public string ChallengerName { get; set; } = string.Empty;

    private bool _challengeCopied = false;

    private async Task CopyChallengeLinkAsync()
    {
        var score = (int)Math.Truncate(assesEaten);
        var name = string.IsNullOrWhiteSpace(CurrentPlayerName) ? "Someone" : CurrentPlayerName.Trim();
        var url = $"{Nav.BaseUri}?challenge={score}&challenger={Uri.EscapeDataString(name)}";
        await Js.InvokeVoidAsync("copyToClipboard", url);
        _challengeCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _challengeCopied = false;
        StateHasChanged();
    }

    public BSModal? Modal;
    private int activeTab = 0;

    // Global stats (Stats tab)
    private GameStats? _globalStats;
    private bool _statsLoading;

    private double ChartMaxCps => clicksPerSecondPolls.Any()
        ? Math.Max(1, clicksPerSecondPolls.Max(p => p.clicksPerSecond) * 1.2)
        : 1;
    private double ChartMaxTime => clicksPerSecondPolls.Any()
        ? Math.Max(1, clicksPerSecondPolls.Max(p => p.timeStamp))
        : 1;

    private string GetChartPoints()
    {
        if (!clicksPerSecondPolls.Any()) return "";
        var mCps = ChartMaxCps;
        var mTime = ChartMaxTime;
        return string.Join(" ", clicksPerSecondPolls.Select(p =>
        {
            var x = (400.0 * p.timeStamp) / mTime;
            var y = 160 - ((160.0 * p.clicksPerSecond) / mCps);
            return $"{x:F1},{y:F1}";
        }));
    }

    private double GetChartDotX(int ts) => (400.0 * ts) / ChartMaxTime;
    private double GetChartDotY(double cps) => 160 - ((160.0 * cps) / ChartMaxCps);

    private double GetClicksPerMinute()
    {
        if (GameDurationSeconds <= 0 || totalClicks == 0) return 0;
        return Math.Round(totalClicks / (GameDurationSeconds / 60.0), 1);
    }

    private double GetTotalPointsForType(AssTypeEnum assType)
    {
        var count = Breakdown.ContainsKey(assType) ? Breakdown[assType] : 0;
        return count * BlazorApp.Shared.Assets.GetPointsForAssType(assType);
    }

    private long GlobalTotalAssesEaten() =>
        _globalStats?.AssTypeStats.Values.Sum() ?? 0;

    private long GlobalAvgClicksPerRound() =>
        _globalStats is { RoundsPlayed: > 0 }
            ? _globalStats.TotalClicks / _globalStats.RoundsPlayed
            : 0;

    private async Task SwitchTab(int tab)
    {
        activeTab = tab;
        if (tab == 2 && !_statsLoading)
        {
            _statsLoading = true;
            _globalStats = await StatsService.GetStatsAsync();
            _statsLoading = false;
        }
    }
}

<BSModal @ref="Modal" Id="resultsModal" IsVerticallyCentered="true" Size="ModalSize.Large">
    <Body>
        <div class="rm-shell">

            <!-- Score header -->
            <div class="rm-header">
                <div class="rm-score-number @(IsPersonalBest ? "rm-score-pb" : "")">@Math.Truncate(assesEaten)</div>
                <div class="rm-score-label">Asses Devoured</div>
                @if (IsPersonalBest)
                {
                    <div class="rm-pb-badge">
                        <i class="bi bi-stars rm-pb-star"></i>
                        <span>Personal Best</span>
                    </div>
                }
                else if (PersonalBestScore.HasValue)
                {
                    <div class="rm-prev-best">
                        Your best: @Math.Truncate(PersonalBestScore.Value)
                    </div>
                }
                @if (!string.IsNullOrEmpty(scoreText))
                {
                    <div class="rm-score-msg">@scoreText</div>
                }
                @if (ChallengeScore > 0)
                {
                    @if (assesEaten > ChallengeScore)
                    {
                        <div class="rm-challenge-result rm-challenge-beaten">
                            <i class="bi bi-trophy-fill"></i>
                            Challenge beaten! You beat @ChallengerName's score of @((int)ChallengeScore)!
                        </div>
                    }
                    else
                    {
                        <div class="rm-challenge-result rm-challenge-missed">
                            <i class="bi bi-trophy"></i>
                            @ChallengerName challenged you to beat @((int)ChallengeScore)
                        </div>
                    }
                }
            </div>

            <!-- Key stats strip -->
            <div class="rm-stats-strip">
                <div class="rm-stat">
                    <i class="bi bi-mouse rm-stat-icon"></i>
                    <span class="rm-stat-val">@totalClicks</span>
                    <span class="rm-stat-lbl">Clicks</span>
                </div>
                <div class="rm-stat-divider"></div>
                <div class="rm-stat">
                    <i class="bi bi-speedometer2 rm-stat-icon"></i>
                    <span class="rm-stat-val">@(GameDurationSeconds > 0 ? Math.Round(totalClicks / GameDurationSeconds, 1) : 0)</span>
                    <span class="rm-stat-lbl">CPS</span>
                </div>
                <div class="rm-stat-divider"></div>
                <div class="rm-stat">
                    <i class="bi bi-stopwatch rm-stat-icon"></i>
                    <span class="rm-stat-val">@GetClicksPerMinute()</span>
                    <span class="rm-stat-lbl">CPM</span>
                </div>
                <div class="rm-stat-divider"></div>
                <div class="rm-stat">
                    <i class="bi bi-bullseye rm-stat-icon"></i>
                    <span class="rm-stat-val">@(totalClicks > 0 ? Math.Round(assesEaten / totalClicks, 3) : 0)</span>
                    <span class="rm-stat-lbl">Pts/Click</span>
                </div>
                @if (peakComboCount >= 1)
                {
                    <div class="rm-stat-row-break"></div>
                    <div class="rm-stat">
                        <i class="bi bi-fire rm-stat-icon rm-stat-fire"></i>
                        <span class="rm-stat-val rm-stat-fire">@peakComboCount</span>
                        <span class="rm-stat-lbl">Frenzies</span>
                    </div>
                    @if (PeakChainLevel >= 2)
                    {
                        <div class="rm-stat-divider"></div>
                        <div class="rm-stat">
                            <i class="bi bi-lightning-charge-fill rm-stat-icon rm-stat-chain"></i>
                            <span class="rm-stat-val rm-stat-chain">X@(PeakChainLevel)</span>
                            <span class="rm-stat-lbl">Peak Chain</span>
                        </div>
                    }
                }
            </div>

            <!-- Actions — above tabs -->
            <div class="rm-actions">
                <button class="rm-btn rm-btn-saving" disabled style="@(IsAutoSaving ? "" : "display:none")">
                    <span class="spinner-border spinner-border-sm" role="status"></span> <span class="rm-btn-label">Saving...</span>
                </button>
                <button class="rm-btn rm-btn-saved" disabled style="@(hasScoreSaved && !IsAutoSaving ? "" : "display:none")">
                    <i class="bi bi-check-lg"></i> <span class="rm-btn-label">Saved</span>
                </button>
                <button class="rm-btn rm-btn-primary" @onclick="() => OnSaveScore.InvokeAsync()"
                        disabled="@(!PersonalBestScore.HasValue || assesEaten > PersonalBestScore.Value ? false : true)"
                        style="@(!hasScoreSaved && !IsAutoSaving && string.IsNullOrEmpty(CurrentPlayerName) ? "" : "display:none")">
                    <i class="bi bi-floppy"></i> <span class="rm-btn-label">Save Score</span>
                </button>
                <button class="rm-btn" @onclick="() => OnShowLeaderboard.InvokeAsync()">
                    <i class="bi bi-trophy"></i> <span class="rm-btn-label">Leaderboard</span>
                </button>
                <button class="rm-btn rm-btn-challenge" @onclick="CopyChallengeLinkAsync" title="Copy challenge link to clipboard">
                    <i class="bi bi-check-lg" style="@(_challengeCopied ? "" : "display:none")"></i>
                    <i class="bi bi-share" style="@(!_challengeCopied ? "" : "display:none")"></i>
                    <span class="rm-btn-label">@(_challengeCopied ? "Copied!" : "Challenge")</span>
                </button>
                <button class="rm-btn rm-btn-ghost" @onclick="() => Modal?.Hide()">
                    <i class="bi bi-x-lg"></i> <span class="rm-btn-label">Close</span>
                </button>
            </div>

            <!-- Material underline tabs -->
            <div class="rm-tab-bar">
                <button class="rm-tab @(activeTab == 0 ? "rm-tab-active" : "")" @onclick="() => SwitchTab(0)">
                    <i class="bi bi-graph-up-arrow"></i> Performance
                </button>
                <button class="rm-tab @(activeTab == 1 ? "rm-tab-active" : "")" @onclick="() => SwitchTab(1)">
                    <i class="bi bi-pie-chart-fill"></i> Breakdown
                </button>
                <button class="rm-tab @(activeTab == 2 ? "rm-tab-active" : "")" @onclick="() => SwitchTab(2)">
                    <i class="bi bi-bar-chart-line-fill"></i> Global Stats
                </button>
            </div>

            <!-- Tab content -->
            <div class="rm-tab-content">
                @if (activeTab == 0)
                {
                    if (clicksPerSecondPolls.Count > 0)
                    {
                        <div class="rm-chart-grid">
                            <div class="rm-y-axis">
                                <div class="rm-y-label">@Math.Round(ChartMaxCps, 1)</div>
                                <div class="rm-y-label">@Math.Round(ChartMaxCps * 0.75, 1)</div>
                                <div class="rm-y-label">@Math.Round(ChartMaxCps * 0.5, 1)</div>
                                <div class="rm-y-label">@Math.Round(ChartMaxCps * 0.25, 1)</div>
                                <div class="rm-y-label">0</div>
                            </div>
                            <div class="rm-chart-area">
                                <svg viewBox="0 0 400 160" class="rm-chart-svg">
                                    <line x1="0" y1="0"   x2="400" y2="0"   stroke="rgba(255,255,255,0.08)" stroke-width="1" />
                                    <line x1="0" y1="40"  x2="400" y2="40"  stroke="rgba(255,255,255,0.08)" stroke-width="1" />
                                    <line x1="0" y1="80"  x2="400" y2="80"  stroke="rgba(255,255,255,0.08)" stroke-width="1" />
                                    <line x1="0" y1="120" x2="400" y2="120" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
                                    <line x1="0" y1="160" x2="400" y2="160" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
                                    @if (clicksPerSecondPolls.Count > 1)
                                    {
                                        <polyline points="@GetChartPoints()"
                                                  fill="none" stroke="#7986cb"
                                                  stroke-width="2.5"
                                                  stroke-linecap="round" stroke-linejoin="round" />
                                    }
                                    @foreach (var poll in clicksPerSecondPolls)
                                    {
                                        <circle cx="@GetChartDotX(poll.timeStamp)" cy="@GetChartDotY(poll.clicksPerSecond)"
                                                r="4" fill="#7986cb" stroke="#1a1a2e" stroke-width="2">
                                            <title>@(poll.timeStamp)s: @poll.clicksPerSecond cps</title>
                                        </circle>
                                    }
                                </svg>
                            </div>
                            <div class="rm-x-spacer"></div>
                            <div class="rm-x-axis">
                                <div class="rm-x-label">0s</div>
                                <div class="rm-x-label">@((int)(ChartMaxTime * 0.25))s</div>
                                <div class="rm-x-label">@((int)(ChartMaxTime * 0.5))s</div>
                                <div class="rm-x-label">@((int)(ChartMaxTime * 0.75))s</div>
                                <div class="rm-x-label">@((int)ChartMaxTime)s</div>
                            </div>
                        </div>
                        <div class="rm-chart-meta">
                            <span><i class="bi bi-arrow-up-circle"></i> Peak: @Math.Round(clicksPerSecondPolls.Max(p => p.clicksPerSecond), 1) cps</span>
                            <span><i class="bi bi-dash-circle"></i> Avg: @Math.Round(clicksPerSecondPolls.Average(p => p.clicksPerSecond), 1) cps</span>
                            <span><i class="bi bi-collection"></i> @clicksPerSecondPolls.Count points</span>
                        </div>
                    }
                    else
                    {
                        <div class="rm-empty">No performance data</div>
                    }
                }
                else if (activeTab == 1)
                {
                    <div class="rm-breakdown">
                        @foreach (var ass in AssTypes.OrderByDescending(a => Breakdown[a]))
                        {
                            var totalConsumed = AssTypes.Sum(a => Breakdown[a]);
                            var pct = totalConsumed > 0 ? Math.Round((double)Breakdown[ass] / totalConsumed * 100, 1) : 0;
                            var barWidth = totalConsumed > 0 ? (double)Breakdown[ass] / totalConsumed * 100 : 0;
                            <div class="rm-bd-row">
                                <img src="/images/Asses/@ass.ToString()/entire_ass.png"
                                     class="rm-bd-img" alt="@ass" />
                                <div class="rm-bd-info">
                                    <div class="rm-bd-name">@ass</div>
                                    <div class="rm-bd-bar-track">
                                        <div class="rm-bd-bar-fill" style="width:@(barWidth)%"></div>
                                    </div>
                                </div>
                                <div class="rm-bd-nums">
                                    <span class="rm-bd-count">@Breakdown[ass]</span>
                                    <span class="rm-bd-pct">@pct%</span>
                                </div>
                                <button class="rm-dex-btn" title="View in Assdex"
                                        @onclick="() => OnShowAssdex.InvokeAsync(ass)">
                                    <i class="bi bi-book"></i> Dex
                                </button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- Global Stats tab -->
                    @if (_statsLoading)
                    {
                        <div class="rm-empty">
                            <div class="spinner-border spinner-border-sm text-secondary me-2" role="status"></div>
                            Loading global stats...
                        </div>
                    }
                    else if (_globalStats == null)
                    {
                        <div class="rm-empty">Could not load global stats.</div>
                    }
                    else
                    {
                        <div class="rm-gs-grid">
                            <div class="rm-gs-stat">
                                <i class="bi bi-emoji-dizzy rm-gs-icon"></i>
                                <span class="rm-gs-val">@GlobalTotalAssesEaten().ToString("N0")</span>
                                <span class="rm-gs-lbl">Asses Eaten</span>
                            </div>
                            <div class="rm-gs-stat">
                                <i class="bi bi-mouse rm-gs-icon"></i>
                                <span class="rm-gs-val">@_globalStats.TotalClicks.ToString("N0")</span>
                                <span class="rm-gs-lbl">Total Clicks</span>
                            </div>
                            <div class="rm-gs-stat">
                                <i class="bi bi-controller rm-gs-icon"></i>
                                <span class="rm-gs-val">@_globalStats.RoundsPlayed.ToString("N0")</span>
                                <span class="rm-gs-lbl">Rounds Played</span>
                            </div>
                            <div class="rm-gs-stat">
                                <i class="bi bi-cursor rm-gs-icon"></i>
                                <span class="rm-gs-val">@GlobalAvgClicksPerRound().ToString("N0")</span>
                                <span class="rm-gs-lbl">Avg Clicks/Round</span>
                            </div>
                        </div>
                        <div class="rm-gs-divider"></div>
                        <div class="rm-gs-section-label">By Ass Type</div>
                        <div class="rm-breakdown">
                            @foreach (var kv in _globalStats.AssTypeStats.OrderByDescending(x => x.Value))
                            {
                                var total = GlobalTotalAssesEaten();
                                var pct = total > 0 ? Math.Round((double)kv.Value / total * 100, 1) : 0;
                                var barW = total > 0 ? (double)kv.Value / total * 100 : 0;
                                <div class="rm-bd-row">
                                    <img src="/images/Asses/@kv.Key/entire_ass.png"
                                         class="rm-bd-img" alt="@kv.Key" />
                                    <div class="rm-bd-info">
                                        <div class="rm-bd-name">@kv.Key</div>
                                        <div class="rm-bd-bar-track">
                                            <div class="rm-bd-bar-fill" style="width:@(barW)%"></div>
                                        </div>
                                    </div>
                                    <div class="rm-bd-nums">
                                        <span class="rm-bd-count">@kv.Value.ToString("N0")</span>
                                        <span class="rm-bd-pct">@pct%</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>

        </div>
    </Body>
</BSModal>
