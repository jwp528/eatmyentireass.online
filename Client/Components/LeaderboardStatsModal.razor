@using BlazorApp.Shared

<BSModal @ref="Modal" Id="leaderboardStatsModal" IsVerticallyCentered="true" Size="ModalSize.ExtraLarge">
    <Body>
        <div class="lb-container">

            <!-- Tab bar -->
            <div class="lb-tab-bar">
                <button class="lb-tab @(activeTab == "alltime" ? "lb-tab-active" : "")" @onclick='() => SwitchTab("alltime")'>
                    <i class="bi bi-globe2"></i> <span class="lb-tab-label">All Time</span>
                </button>
                <button class="lb-tab @(activeTab == "daily" ? "lb-tab-active" : "")" @onclick='() => SwitchTab("daily")'>
                    <i class="bi bi-sun"></i> <span class="lb-tab-label">Daily</span>
                </button>
                <button class="lb-tab @(activeTab == "monthly" ? "lb-tab-active" : "")" @onclick='() => SwitchTab("monthly")'>
                    <i class="bi bi-calendar3"></i> <span class="lb-tab-label">Monthly</span>
                </button>
                <button class="lb-tab @(activeTab == "yearly" ? "lb-tab-active" : "")" @onclick='() => SwitchTab("yearly")'>
                    <i class="bi bi-star"></i> <span class="lb-tab-label">Yearly</span>
                </button>
            </div>

            <!-- Leaderboard content -->
            <div class="lb-search-bar">
                <i class="bi bi-search lb-search-icon"></i>
                <input type="text" class="lb-search-input" placeholder="Search player…"
                       @bind="_searchText" @bind:event="oninput" />
            </div>

            @if (isLoadingLeaderboard)
            {
                <div class="lb-empty">
                    <div class="spinner-border spinner-border-sm text-warning mb-2" role="status"></div>
                    <span>Loading scores…</span>
                </div>
            }
            else if (!CurrentScores.Any())
            {
                <div class="lb-empty">
                    <i class="bi bi-trophy" style="font-size:2rem; opacity:0.25; display:block; margin-bottom:8px;"></i>
                    No scores yet. Be the first!
                </div>
            }
            else if (!CurrentScoresFiltered.Any())
            {
                <div class="lb-empty">
                    <i class="bi bi-search" style="font-size:1.6rem; opacity:0.25; display:block; margin-bottom:8px;"></i>
                    No players match "@_searchText"
                </div>
            }
            else
            {
                <div class="lb-content">
                    <!-- Header row -->
                    <div class="lb-row lb-header-row">
                        <div class="lb-col-rank"></div>
                        <div class="lb-col-name">Player</div>
                        <div class="lb-col-score">Score</div>
                        <div class="lb-col-cps">CPS</div>
                        <div class="lb-col-date">Date</div>
                    </div>

                    @for (int i = 0; i < CurrentScoresFiltered.Count; i++)
                    {
                        var entry = CurrentScoresFiltered[i];
                        var rank = CurrentScores.IndexOf(entry) + 1;
                        <div class="lb-row @(rank == 1 ? "lb-row-gold" : rank == 2 ? "lb-row-silver" : rank == 3 ? "lb-row-bronze" : "")">
                            <div class="lb-col-rank">
                                @if (rank == 1)     { <span class="lb-medal">🥇</span> }
                                else if (rank == 2) { <span class="lb-medal">🥈</span> }
                                else if (rank == 3) { <span class="lb-medal">🥉</span> }
                                else                { <span class="lb-rank-num">@rank</span> }
                            </div>
                            <div class="lb-col-name lb-player-name">@entry.PlayerName</div>
                            <div class="lb-col-score lb-val-score">@((int)Math.Truncate(entry.Score))</div>
                            <div class="lb-col-cps lb-val-cps">@entry.CPS</div>
                            <div class="lb-col-date lb-val-date">
                                @entry.GameDate.ToString("MMM d")
                                <span class="lb-time">@entry.GameDate.ToString("HH:mm")</span>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Footer actions -->
            <div class="lb-actions">
                <button class="lb-btn" @onclick="Refresh" disabled="@isLoadingLeaderboard">
                    <i class="bi bi-arrow-clockwise"></i> Refresh
                </button>
                <button class="lb-btn" @onclick="CloseModal">
                    <i class="bi bi-x-lg"></i> Close
                </button>
            </div>

        </div>
    </Body>
</BSModal>
