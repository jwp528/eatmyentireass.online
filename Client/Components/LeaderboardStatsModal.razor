@using BlazorApp.Shared

<BSModal @ref="Modal" Id="leaderboardStatsModal" IsVerticallyCentered="true" Size="ModalSize.ExtraLarge">
    <Body>
        <div class="lb-stats-container">
            <!-- Tab navigation -->
            <div class="tab-header mb-4">
                <button class="tab-btn @(activeTab == "leaderboard" ? "active" : "")"
                        @onclick='() => SwitchTab("leaderboard")'>
                    <i class="fas fa-trophy me-2"></i>Leaderboard
                </button>
                <button class="tab-btn @(activeTab == "stats" ? "active" : "")"
                        @onclick='() => SwitchTab("stats")'>
                    <i class="fas fa-chart-bar me-2"></i>Global Stats
                </button>
            </div>

            <!-- Leaderboard tab -->
            @if (activeTab == "leaderboard")
            {
                <div class="text-center mb-3">
                    <small class="text-muted">
                        <i class="fas fa-globe me-1"></i>Shared across all players worldwide
                    </small>
                </div>

                @if (isLoadingLeaderboard)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-warning" role="status"></div>
                        <p class="mt-2 text-muted">Loading scores...</p>
                    </div>
                }
                else if (!topScores.Any())
                {
                    <div class="text-center py-5">
                        <i class="fas fa-chart-line fa-3x text-muted mb-3"></i>
                        <h6 class="text-muted">No scores yet!</h6>
                        <p class="text-muted mb-0">Be the first to set a high score!</p>
                    </div>
                }
                else
                {
                    <div class="lb-content">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-muted small">
                                <i class="fas fa-list-ol me-1"></i>Top @topScores.Count Scores
                            </span>
                            <span class="text-muted small">
                                <i class="fas fa-globe me-1"></i>Global scores
                            </span>
                        </div>

                        <div class="row fw-bold border-bottom pb-2 mb-2 text-muted small text-uppercase">
                            <div class="col-1">#</div>
                            <div class="col-3">Player</div>
                            <div class="col-2">Score</div>
                            <div class="col-2">Clicks</div>
                            <div class="col-2">CPS</div>
                            <div class="col-2">Date</div>
                        </div>

                        @for (int i = 0; i < topScores.Count; i++)
                        {
                            var entry = topScores[i];
                            var rank = i + 1;
                            <div class="row align-items-center py-2 my-1 @(rank <= 3 ? "top-score" : "") border-bottom lb-row">
                                <div class="col-1">
                                    @if (rank == 1)      { <i class="fas fa-crown text-warning fs-5"></i> }
                                    else if (rank == 2)  { <i class="fas fa-medal text-secondary fs-5"></i> }
                                    else if (rank == 3)  { <i class="fas fa-award text-warning fs-5"></i> }
                                    else                 { <span class="text-muted small fw-bold">#@rank</span> }
                                </div>
                                <div class="col-3"><span class="fw-semibold text-white">@entry.PlayerName</span></div>
                                <div class="col-2"><span class="fw-bold text-success">@Math.Truncate(entry.Score)</span></div>
                                <div class="col-2"><span class="text-info">@entry.TotalClicks</span></div>
                                <div class="col-2"><span class="text-warning">@entry.CPS</span></div>
                                <div class="col-2">
                                    <span class="text-muted small">@entry.GameDate.ToString("MMM dd")</span><br />
                                    <span class="text-muted" style="font-size:0.7rem">@entry.GameDate.ToString("HH:mm")</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            }

            <!-- Stats tab -->
            @if (activeTab == "stats")
            {
                <div class="text-center mb-3">
                    <small class="text-muted">
                        <i class="fas fa-globe me-1"></i>Aggregated across all players worldwide
                    </small>
                </div>

                @if (isLoadingStats)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">Loading global stats...</p>
                    </div>
                }
                else if (stats == null)
                {
                    <div class="text-center py-5">
                        <i class="fas fa-exclamation-triangle fa-3x text-warning mb-3"></i>
                        <p class="text-muted">Could not load stats. API may be unavailable.</p>
                    </div>
                }
                else
                {
                    <div class="stats-grid mb-4">
                        <div class="stat-card">
                            <i class="fas fa-mouse-pointer text-primary stat-icon"></i>
                            <div class="stat-value">@stats.TotalClicks.ToString("N0")</div>
                            <div class="stat-label">Total Clicks</div>
                        </div>
                        <div class="stat-card">
                            <i class="fas fa-gamepad text-success stat-icon"></i>
                            <div class="stat-value">@stats.RoundsPlayed.ToString("N0")</div>
                            <div class="stat-label">Rounds Played</div>
                        </div>
                        <div class="stat-card">
                            <i class="fas fa-clock text-warning stat-icon"></i>
                            <div class="stat-value">@FormatTime(stats.TotalTimePlayedSeconds)</div>
                            <div class="stat-label">Total Time Played</div>
                        </div>
                        <div class="stat-card">
                            <i class="fas fa-fire text-danger stat-icon"></i>
                            <div class="stat-value">@TotalAssesEaten().ToString("N0")</div>
                            <div class="stat-label">Total Asses Eaten</div>
                        </div>
                    </div>

                    <div class="ass-breakdown-section">
                        <h6 class="text-muted text-uppercase mb-3 small fw-bold">
                            <i class="fas fa-chart-pie me-2"></i>By Ass Type
                        </h6>
                        <div class="ass-breakdown-grid">
                            @foreach (var assType in new[] { "Cartoon", "Flat", "Hairy", "GYAT", "Golden", "Boney" })
                            {
                                var count = GetAssTypeCount(assType);
                                var total = TotalAssesEaten();
                                var pct = total > 0 ? (double)count / total * 100 : 0;
                                <div class="ass-type-row">
                                    <img src="/images/Asses/@assType/entire_ass.png" class="ass-type-icon" alt="@assType" />
                                    <div class="ass-type-info flex-grow-1">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="ass-type-name">@assType</span>
                                            <span class="ass-type-count">@count.ToString("N0")</span>
                                        </div>
                                        <div class="progress ass-progress">
                                            <div class="progress-bar" style="width: @pct.ToString("F1")%"></div>
                                        </div>
                                    </div>
                                    <span class="ass-pct text-muted small">@pct.ToString("F1")%</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="text-end mt-2">
                        <small class="text-muted">Last updated: @stats.LastUpdated.ToString("MMM dd, yyyy HH:mm") UTC</small>
                    </div>
                }
            }

            <!-- Footer actions -->
            <div class="lb-actions mt-4">
                <div class="d-flex justify-content-between align-items-center">
                    <button type="button" class="btn btn-big-rounded btn-primary"
                            @onclick="Refresh"
                            disabled="@(isLoadingLeaderboard || isLoadingStats)">
                        <i class="fas fa-sync-alt me-2"></i>Refresh
                    </button>
                    <button type="button" class="btn btn-big-rounded btn-secondary" @onclick="CloseModal">
                        <i class="fas fa-times me-2"></i>Close
                    </button>
                </div>
            </div>
        </div>
    </Body>
</BSModal>
