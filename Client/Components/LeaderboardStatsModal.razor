@using BlazorApp.Shared

<BSModal @ref="Modal" Id="leaderboardStatsModal" IsVerticallyCentered="true" Size="ModalSize.ExtraLarge">
    <Body>
        <div class="lb-container">

            <!-- Tab bar -->
            <div class="lb-tab-bar">
                <button class="lb-tab @(activeTab == "alltime" ? "lb-tab-active" : "")" @onclick='() => SwitchTab("alltime")'>
                    <i class="bi bi-globe2"></i> <span class="lb-tab-label">All Time</span>
                </button>
                <button class="lb-tab @(activeTab == "daily" ? "lb-tab-active" : "")" @onclick='() => SwitchTab("daily")'>
                    <i class="bi bi-sun"></i> <span class="lb-tab-label">Daily</span>
                </button>
                <button class="lb-tab @(activeTab == "monthly" ? "lb-tab-active" : "")" @onclick='() => SwitchTab("monthly")'>
                    <i class="bi bi-calendar3"></i> <span class="lb-tab-label">Monthly</span>
                </button>
                <button class="lb-tab @(activeTab == "yearly" ? "lb-tab-active" : "")" @onclick='() => SwitchTab("yearly")'>
                    <i class="bi bi-star"></i> <span class="lb-tab-label">Yearly</span>
                </button>
            </div>

            <!-- Leaderboard content -->
            <div class="lb-search-bar">
                <i class="bi bi-search lb-search-icon"></i>
                <input type="text" class="lb-search-input" placeholder="Search player…"
                       @bind="_searchText" @bind:event="oninput" />
            </div>

            @if (isLoadingLeaderboard)
            {
                <div class="lb-empty">
                    <div class="spinner-border spinner-border-sm text-warning mb-2" role="status"></div>
                    <span>Loading scores…</span>
                </div>
            }
            else if (!CurrentScores.Any())
            {
                <div class="lb-empty">
                    <i class="bi bi-trophy" style="font-size:2rem; opacity:0.25; display:block; margin-bottom:8px;"></i>
                    No scores yet. Be the first!
                </div>
            }
            else if (!CurrentScoresFiltered.Any())
            {
                <div class="lb-empty">
                    <i class="bi bi-search" style="font-size:1.6rem; opacity:0.25; display:block; margin-bottom:8px;"></i>
                    No players match "@_searchText"
                </div>
            }
            else
            {
                <div class="lb-content">
                    <!-- Header row -->
                    <div class="lb-row lb-header-row">
                        <div class="lb-col-rank"></div>
                        <div class="lb-col-name">Player</div>
                        <div class="lb-col-score">Score</div>
                        <div class="lb-col-cps">CPS</div>
                        <div class="lb-col-frenzies">Frnzy</div>
                        <div class="lb-col-chain">Chain</div>
                        <div class="lb-col-date">Date</div>
                    </div>

                    @for (int i = 0; i < CurrentScoresFiltered.Count; i++)
                    {
                        var entry = CurrentScoresFiltered[i];
                        var rank = CurrentScores.IndexOf(entry) + 1;
                        <div class="lb-row @(rank == 1 ? "lb-row-gold" : rank == 2 ? "lb-row-silver" : rank == 3 ? "lb-row-bronze" : "")">
                            <div class="lb-col-rank">
                                @if (rank == 1)     { <span class="lb-medal">🥇</span> }
                                else if (rank == 2) { <span class="lb-medal">🥈</span> }
                                else if (rank == 3) { <span class="lb-medal">🥉</span> }
                                else                { <span class="lb-rank-num">@rank</span> }
                            </div>
                            <div class="lb-col-name">
                                <button type="button" class="lb-player-btn lb-player-name" @onclick="() => ShowEntryDetails(entry, rank)">
                                    @entry.PlayerName
                                </button>
                            </div>
                            <div class="lb-col-score lb-val-score">@(((int)Math.Truncate(entry.Score)).ToString("N0"))</div>
                            <div class="lb-col-cps lb-val-cps">@entry.CPS</div>
                            <div class="lb-col-frenzies lb-val-frenzies">@(entry.FrenzyCount.HasValue ? entry.FrenzyCount.Value.ToString() : "-")</div>
                            <div class="lb-col-chain lb-val-chain">@(entry.PeakFrenzyChain.HasValue ? entry.PeakFrenzyChain.Value.ToString() : "-")</div>
                            <div class="lb-col-date lb-val-date">
                                @entry.GameDate.ToString("MMM d")
                                <span class="lb-time">@entry.GameDate.ToString("HH:mm")</span>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Footer actions -->
            <div class="lb-actions">
                <button class="lb-btn" @onclick="Refresh" disabled="@isLoadingLeaderboard">
                    <i class="bi bi-arrow-clockwise"></i> Refresh
                </button>
                <button class="lb-btn" @onclick="CloseModal">
                    <i class="bi bi-x-lg"></i> Close
                </button>
            </div>

        </div>
    </Body>
</BSModal>

<BSModal @ref="DetailsModal" Id="leaderboardGameDetailsModal" IsVerticallyCentered="true" Size="ModalSize.Large">
    <Body>
        @if (_selectedEntry != null)
        {
            <div class="lb-detail-shell">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                    <div>
                        <div class="lb-detail-title">Game Details</div>
                        <div class="lb-detail-subtitle">
                            <span class="lb-detail-rank">#@_selectedRank</span>
                            @_selectedEntry.PlayerName
                        </div>
                    </div>
                    <button type="button" class="lb-btn lb-btn-icon" @onclick="CloseDetailsModal" aria-label="Close game details">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <div class="row g-2">
                    <div class="col-6 col-md-4"><div class="lb-detail-stat"><span>Score</span><strong>@(((int)_selectedEntry.Score).ToString("N0"))</strong></div></div>
                    <div class="col-6 col-md-4"><div class="lb-detail-stat"><span>Total Clicks</span><strong>@_selectedEntry.TotalClicks.ToString("N0")</strong></div></div>
                    <div class="col-6 col-md-4"><div class="lb-detail-stat"><span>CPS</span><strong>@_selectedEntry.CPS</strong></div></div>
                    <div class="col-6 col-md-4"><div class="lb-detail-stat"><span>Efficiency</span><strong>@_selectedEntry.ClickEfficiency</strong></div></div>
                    <div class="col-6 col-md-4"><div class="lb-detail-stat"><span>Frenzies</span><strong>@(_selectedEntry.FrenzyCount?.ToString() ?? "-")</strong></div></div>
                    <div class="col-6 col-md-4"><div class="lb-detail-stat"><span>Peak Chain</span><strong>@(_selectedEntry.PeakFrenzyChain?.ToString() ?? "-")</strong></div></div>
                    <div class="col-6 col-md-4"><div class="lb-detail-stat"><span>Duration</span><strong>@_selectedEntry.GameDurationSeconds s</strong></div></div>
                    <div class="col-6 col-md-8"><div class="lb-detail-stat"><span>Played At</span><strong>@_selectedEntry.GameDate.ToString("MMM d, yyyy HH:mm")</strong></div></div>
                </div>

                <div class="lb-detail-section-title">Breakdown</div>
                @{
                    var breakdownItems = SelectedBreakdown;
                }
                @if (breakdownItems.Any())
                {
                    var totalBreakdown = breakdownItems.Sum(x => x.Value);
                    <div class="lb-detail-breakdown">
                        @foreach (var item in breakdownItems)
                        {
                            var percent = totalBreakdown > 0 ? Math.Round((double)item.Value * 100 / totalBreakdown, 1) : 0;
                            <div class="lb-detail-row">
                                <div class="lb-detail-type">@item.Key</div>
                                <div class="progress lb-detail-progress">
                                    <div class="progress-bar lb-detail-progress-bar" role="progressbar" style="width:@percent%"></div>
                                </div>
                                <div class="lb-detail-value">@item.Value <span>@percent%</span></div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="lb-empty lb-detail-empty">No per-type breakdown was captured for this game.</div>
                }

                <div class="lb-actions lb-detail-actions">
                    <button class="lb-btn" @onclick="CloseDetailsModal">
                        <i class="bi bi-x-lg"></i> Close
                    </button>
                </div>
            </div>
        }
    </Body>
</BSModal>
