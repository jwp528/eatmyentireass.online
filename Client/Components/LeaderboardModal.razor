@using BlazorApp.Shared

<BSModal @ref="Modal" Id="leaderboardModal" IsVerticallyCentered="true" Size="ModalSize.ExtraLarge">
    <Body>
        <div class="leaderboard-container">
            <!-- Modal Title -->
            <div class="text-center mb-4">
                <h4 class="fw-bold text-white mb-0">
                    <i class="fas fa-trophy text-warning me-2"></i>
                    Global Leaderboard
                </h4>
                <small class="text-muted">
                    <i class="fas fa-globe me-1"></i>
                    Shared across all players - updates require file replacement
                </small>
            </div>

            @if (isLoading)
            {
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2 text-muted">Loading your local scores...</p>
                </div>
            }
            else if (!topScores.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-chart-line fa-3x text-muted mb-3"></i>
                    <h6 class="text-muted">No scores yet!</h6>
                    <p class="text-muted mb-0">Be the first to set a high score on the global leaderboard!</p>
                    <div class="mt-3">
                        <i class="fas fa-info-circle text-info me-1"></i>
                        <small class="text-info">Scores are shared globally via file updates</small>
                    </div>
                </div>
            }
            else
            {
                <div class="leaderboard-content">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted">
                            <i class="fas fa-list-ol me-1"></i>
                            Top @topScores.Count Scores
                        </span>
                        <span class="text-muted small">
                            <i class="fas fa-globe me-1"></i>
                            Global scores
                        </span>
                    </div>

                    <div class="row fw-bold border-bottom pb-2 mb-3 text-muted small text-uppercase">
                        <div class="col-1">#</div>
                        <div class="col-3">Player</div>
                        <div class="col-2">Score</div>
                        <div class="col-2">Clicks</div>
                        <div class="col-2">CPS</div>
                        <div class="col-2">Date</div>
                    </div>
                    
                    @for (int i = 0; i < topScores.Count; i++)
                    {
                        var entry = topScores[i];
                        var rank = i + 1;
                        
                        <div class="row align-items-center py-3 my-2 @(rank <= 3 ? "top-score" : "") border-bottom leaderboard-row">
                            <div class="col-1">
                                @if (rank == 1)
                                {
                                    <i class="fas fa-crown text-warning fs-5" title="1st Place!"></i>
                                }
                                else if (rank == 2)
                                {
                                    <i class="fas fa-medal text-secondary fs-5" title="2nd Place!"></i>
                                }
                                else if (rank == 3)
                                {
                                    <i class="fas fa-award text-warning fs-5" title="3rd Place!"></i>
                                }
                                else
                                {
                                    <span class="text-muted small fw-bold">#@rank</span>
                                }
                            </div>
                            <div class="col-3">
                                <span class="fw-semibold text-white">@entry.PlayerName</span>
                            </div>
                            <div class="col-2">
                                <span class="fw-bold text-success">@Math.Truncate(entry.Score)</span>
                            </div>
                            <div class="col-2">
                                <span class="text-info">@entry.TotalClicks</span>
                            </div>
                            <div class="col-2">
                                <span class="text-warning">@entry.CPS</span>
                            </div>
                            <div class="col-2">
                                <span class="text-muted small">@entry.GameDate.ToString("MMM dd")</span>
                                <br />
                                <span class="text-muted" style="font-size: 0.7rem;">@entry.GameDate.ToString("HH:mm")</span>
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Action Buttons -->
            <div class="leaderboard-actions mt-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <button type="button" class="btn btn-big-rounded btn-primary me-3" @onclick="RefreshScores" disabled="@isLoading">
                            <i class="fas fa-sync-alt me-2"></i>
                            Refresh
                        </button>
                        @if (topScores.Any())
                        {
                            <button type="button" class="btn btn-big-rounded btn-outline-danger me-3" @onclick="ClearLeaderboard" disabled="@isLoading">
                                <i class="fas fa-trash me-2"></i>
                                Clear All
                            </button>
                        }
                    </div>
                    <button type="button" class="btn btn-big-rounded btn-secondary" @onclick="CloseModal">
                        <i class="fas fa-times me-2"></i>
                        Close
                    </button>
                </div>
            </div>

            <!-- Global Leaderboard Info -->
            <div class="alert alert-info mt-3 mb-0" role="alert">
                <i class="fas fa-globe me-2"></i>
                <small>
                    <strong>Global Leaderboard:</strong> Scores are shared across all players worldwide.
                    Save your score after each game to compete!
                </small>
            </div>
        </div>
    </Body>
</BSModal>