@code{
    public BSModal? Modal;
}

<BSModal @ref="Modal" Id="aboutModal" IsVerticallyCentered="true" Size="ModalSize.Default">
    <Body>
        <div class="ab-shell">
            <div class="ab-header">
                <img src="https://www.joshparsons.ca/img/Logo.svg" alt="Josh Parsons" class="ab-avatar" />
                <div class="ab-info">
                    <p class="ab-name">Josh Parsons</p>
                    <p class="ab-subtitle">.NET Developer — Cornwall, PEI</p>
                    <div class="ab-links">
                        <a href="https://joshparsons.ca" target="_blank" rel="noopener noreferrer" class="ab-link" title="Website">
                            <i class="fas fa-globe"></i>
                        </a>
                        <a href="https://github.com/jwp528" target="_blank" rel="noopener noreferrer" class="ab-link" title="GitHub">
                            <i class="fab fa-github"></i>
                        </a>
                        <a href="https://www.linkedin.com/in/jparsons93/" target="_blank" rel="noopener noreferrer" class="ab-link" title="LinkedIn">
                            <i class="fab fa-linkedin"></i>
                        </a>
                    </div>
                </div>
            </div>

            <div class="ab-divider"></div>

            <p class="ab-bio">Professional .NET developer specializing in web development and software engineering.</p>
            <p class="ab-bio ab-bio--muted">From Prince Edward Island, I create digital experiences that blend functionality with creativity. This ridiculous game is just one example of what happens when a developer has too much free time.</p>

            <div class="ab-divider"></div>

            <p class="ab-label">Technologies</p>
            <div class="ab-chips">
                <span class="ab-chip">.NET Core</span>
                <span class="ab-chip">Blazor</span>
                <span class="ab-chip">Azure</span>
                <span class="ab-chip">C#</span>
                <span class="ab-chip">JavaScript</span>
                <span class="ab-chip">Bootstrap</span>
            </div>

            <div class="ab-meta">
                <span><i class="fas fa-map-marker-alt"></i> Cornwall, PEI</span>
                <span class="ab-meta-sep">·</span>
                <span>Freelance Developer</span>
                <span class="ab-meta-sep">·</span>
                <span>Coffee Enthusiast</span>
            </div>

            <div class="ab-footer">
                <a href="https://joshparsons.ca" target="_blank" rel="noopener noreferrer" class="ab-btn">
                    <i class="fas fa-external-link-alt"></i> joshparsons.ca
                </a>
                <button type="button" class="ab-btn ab-btn--ghost" @onclick="async () => await Modal?.Hide()">Close</button>
            </div>
        </div>
    </Body>
</BSModal>
