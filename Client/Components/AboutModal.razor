@code{
    public BSModal? Modal;
    [Microsoft.AspNetCore.Components.Parameter]
    public Microsoft.AspNetCore.Components.EventCallback OnShowStats { get; set; }
}

<BSModal @ref="Modal" Id="aboutModal" IsVerticallyCentered="true" Size="ModalSize.Default">
    <Body>
        <div class="ab-shell">
            <div class="ab-header">
                <p class="ab-name">Eat My Entire Ass</p>
                <p class="ab-subtitle">A pointless but very serious competitive eating game.</p>
            </div>

            <div class="ab-divider"></div>

            <p class="ab-bio">
                Built by <a href="https://joshparsons.ca" target="_blank" rel="noopener noreferrer" class="ab-link-inline">Josh Parsons</a> — because someone had to.
            </p>

            <div class="ab-links-row">
                <a href="https://joshparsons.ca" target="_blank" rel="noopener noreferrer" class="ab-link" title="Developer Website">
                    <i class="fas fa-globe"></i> joshparsons.ca
                </a>
                <a href="https://github.com/jwp528/eatmyentireass.online" target="_blank" rel="noopener noreferrer" class="ab-link" title="View Source Code">
                    <i class="fab fa-github"></i> Source Code
                </a>
            </div>

            <div class="ab-footer">
                <button type="button" class="ab-btn ab-btn--ghost" @onclick="async () => { await Modal?.Hide(); await OnShowStats.InvokeAsync(); }">
                    <i class="bi bi-bar-chart-line-fill"></i> Global Stats
                </button>
                <button type="button" class="ab-btn ab-btn--ghost" @onclick="async () => await Modal?.Hide()">Close</button>
            </div>
        </div>
    </Body>
</BSModal>
