@code {
    public enum AssIconStyle
    {
        Outline,
        Fill,
    }

    [Parameter] public string Size { get; set; } = "1em";
    [Parameter] public string Color { get; set; } = "currentColor";
    [Parameter] public AssIconStyle Style { get; set; } = AssIconStyle.Outline;
}

@if (Style == AssIconStyle.Outline)
{
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
         stroke="@Color" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
         width="@Size" height="@Size" aria-hidden="true">
        <path d="M4 9 L20 9" />
        <path d="M4 9 Q3 17 8 21 Q10.5 23 12 21" />
        <path d="M20 9 Q21 17 16 21 Q13.5 23 12 21" />
    </svg>
}
else
{
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
         width="@Size" height="@Size" aria-hidden="true">
        <path d="M4 9 L20 9 Q21 17 16 21 Q13.5 23 12 21 Q10.5 23 8 21 Q3 17 4 9 Z"
              fill="@Color" />
    </svg>
}
